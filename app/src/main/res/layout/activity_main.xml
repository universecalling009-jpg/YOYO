<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F0E8">

    <!-- App Icon / Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚"
        android:textSize="72sp"
        android:layout_marginBottom="8dp"/>

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amit Books"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a book to read"
        android:textSize="16sp"
        android:textColor="#795548"
        android:layout_marginBottom="48dp"/>

    <!-- Divider -->
    <View
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:background="#A1887F"
        android:layout_marginBottom="48dp"/>

    <!-- Book 1 Button -->
    <Button
        android:id="@+id/btnBook1"
        android:layout_width="280dp"
        android:layout_height="72dp"
        android:text="📖  Book 1"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5D4037"
        android:layout_marginBottom="24dp"
        android:elevation="6dp"/>

    <!-- Book 2 Button -->
    <Button
        android:id="@+id/btnBook2"
        android:layout_width="280dp"
        android:layout_height="72dp"
        android:text="📗  Book 2"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        android:elevation="6dp"/>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amit Books © 2024"
        android:textSize="12sp"
        android:textColor="#A1887F"
        android:layout_marginTop="48dp"/>

</LinearLayout>
